# Base44 Configuration
# Replace with your actual Base44 App ID
VITE_BASE44_APP_ID=your_app_id

# Replace with your actual Base44 Backend URL
VITE_BASE44_APP_BASE_URL=your_backend_url

# Example:
# VITE_BASE44_APP_ID=cbef744a8545c389ef439ea6
# VITE_BASE44_APP_BASE_URL=https://my-app-81bfaad7.base44.app

# Optional: Enable legacy SDK imports if needed
# BASE44_LEGACY_SDK_IMPORTS=false
